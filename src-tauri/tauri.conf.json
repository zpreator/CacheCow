{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CacheCow",
  "version": "0.1.0",
  "identifier": "com.cachecow.app",
  "build": {
    "frontendDist": "frontend",
    "devUrl": "http://localhost:8501"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cachecow-server"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "CacheCow",
        "width": 1280,
        "height": 800,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  }
}
